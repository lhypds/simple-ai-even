# Copy to `.env` and fill in. Vite exposes VITE_* vars to the client bundle.
# NOTE: the key ships in the built JS — fine for local testing, not for production.

VITE_OPENAI_API_KEY=sk-...

# Optional. Defaults to whisper-1.
# VITE_OPENAI_MODEL=whisper-1

# Optional ISO-639-1 language hint (e.g. en, ja, zh). Omit for auto-detect.
# VITE_STT_LANGUAGE=en
